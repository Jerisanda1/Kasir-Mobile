<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#EEF0FB">

    <!-- ==================== SIDEBAR KIRI (PERSISTEN, TIDAK IKUT DIGANTI) ==================== -->
    <LinearLayout
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingTop="24dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/logo_jimbomart"
                android:contentDescription="Logo Jimbo Mart"
                android:scaleType="fitCenter"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JIMBO MART"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

        </LinearLayout>

        <!-- Garis pemisah -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- ===== Kontainer menu: indikator aktif (kotak ungu) + 2 menu di atasnya =====
             Indikator ditaruh sebagai child PERTAMA (paling belakang secara z-order),
             lalu digeser (translationY) lewat kode ke posisi menu yang baru diklik. -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <View
                android:id="@+id/vIndikatorAktif"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="@drawable/bg_nav_active"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Menu: Transaksi -->
                <LinearLayout
                    android:id="@+id/llMenuTransaksi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛒"
                        android:textSize="16sp"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:id="@+id/tvLabelTransaksi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transaksi"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <!-- Menu: Riwayat Transaksi -->
                <LinearLayout
                    android:id="@+id/llMenuRiwayat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕐"
                        android:textSize="16sp"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:id="@+id/tvLabelRiwayat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Riwayat Transaksi"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"/>
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>

        <!-- Spacer, mendorong Logout ke bawah -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/ivLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="↩  Logout"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E53935"
            android:backgroundTint="@android:color/transparent"
            android:stateListAnimator="@null"
            android:gravity="start|center_vertical"
            android:paddingStart="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp"/>

    </LinearLayout>

    <!-- ==================== KONTEN KANAN: DIGANTI-GANTI ANTAR FRAGMENT ==================== -->
    <FrameLayout
        android:id="@+id/frameContent"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"/>

</LinearLayout>
