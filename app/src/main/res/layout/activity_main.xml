<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#EEF0FB">

    <!-- ==================== SIDEBAR KIRI (PERSISTEN, TIDAK IKUT DIGANTI) ==================== -->
    <LinearLayout
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingTop="24dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/logo_jimbomart"
                android:contentDescription="Logo Jimbo Mart"
                android:scaleType="fitCenter"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JIMBO MART"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

        </LinearLayout>

        <!-- Garis pemisah -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- ===== Kontainer menu: indikator aktif (kotak ungu) + 2 menu di atasnya ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <View
                android:id="@+id/vIndikatorAktif"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="@drawable/bg_nav_active"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Menu: Transaksi -->
                <LinearLayout
                    android:id="@+id/llMenuTransaksi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/ivIconTransaksi"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/shooping_card"
                        app:tint="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvLabelTransaksi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transaksi"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <!-- Menu: Riwayat Transaksi -->
                <LinearLayout
                    android:id="@+id/llMenuRiwayat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/ivIconRiwayat"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/receipt_long_24px"
                        app:tint="#000000"/>

                    <TextView
                        android:id="@+id/tvLabelRiwayat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Riwayat Transaksi"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"/>
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>

        <!-- Spacer, mendorong info user + tombol tutup shift ke bawah -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Garis pemisah tipis -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="8dp"/>

        <!-- Info user (nama & role) + tombol akhiri shift, dalam 1 baris -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="10dp"
            android:paddingBottom="20dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/account_circle_24px"
                app:tint="#5149E5"
                android:contentDescription="@null"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNamaKasirSidebar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvRoleShiftSidebar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="-"
                    android:textSize="11sp"
                    android:textColor="#78909C"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Tombol akhiri shift: tampilan icon logout saja, tapi alurnya sama seperti
                 "Tutup Shift" (rekonsiliasi kas), BUKAN logout polos -->
            <ImageView
                android:id="@+id/btnTutupShift"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/logout_24px"
                app:tint="#E53935"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Akhiri shift"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ==================== KONTEN KANAN: DIGANTI-GANTI ANTAR FRAGMENT ==================== -->
    <FrameLayout
        android:id="@+id/frameContent"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"/>

</LinearLayout>