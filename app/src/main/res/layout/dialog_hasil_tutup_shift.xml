<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_putih"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ringkasan Shift"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_info_note"
        android:padding="14dp"
        android:layout_marginBottom="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Modal Awal" android:textSize="12sp" android:textColor="#78909C"/>
            <TextView android:id="@+id/tvHasilModalAwal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textSize="12sp" android:textColor="#1A1A2E"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Penjualan Tunai" android:textSize="12sp" android:textColor="#78909C"/>
            <TextView android:id="@+id/tvHasilPenjualan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textSize="12sp" android:textColor="#1A1A2E"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Kas Seharusnya" android:textSize="12sp" android:textColor="#78909C"/>
            <TextView android:id="@+id/tvHasilKasSeharusnya" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textSize="12sp" android:textColor="#1A1A2E"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Kas Fisik" android:textSize="12sp" android:textColor="#78909C"/>
            <TextView android:id="@+id/tvHasilKasFisik" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textSize="12sp" android:textColor="#1A1A2E"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#D0D5F0" android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Selisih" android:textSize="14sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
            <TextView android:id="@+id/tvHasilSelisih" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textSize="14sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvKeteranganSelisih"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kas pas, tidak ada selisih."
        android:textSize="11sp"
        android:textColor="#78909C"
        android:gravity="center"
        android:layout_marginBottom="18dp"/>

    <Button
        android:id="@+id/btnTutupHasilShift"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="OK, Selesai Kerja"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#5149E5"
        android:stateListAnimator="@null"/>

</LinearLayout>