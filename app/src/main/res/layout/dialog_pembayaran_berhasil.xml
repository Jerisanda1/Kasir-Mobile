<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_putih"
    android:padding="28dp"
    android:gravity="center">

    <ImageView
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/konfirm"
        android:alpha="0.4"
        android:layout_marginBottom="12dp"
        android:contentDescription="Pembayaran berhasil"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pembayaran Berhasil"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvKodeTransaksiSukses"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TRX-000000"
        android:textSize="12sp"
        android:textColor="#78909C"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCetakNota"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cetak Nota"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#5149E5"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="#E3E8FD"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnTransaksiBaru"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Transaksi Baru"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="#5149E5"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</LinearLayout>