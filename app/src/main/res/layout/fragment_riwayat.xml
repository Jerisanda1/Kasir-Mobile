<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="2dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="#5149E5"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Judul -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivIconRiwayat"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/receipt_long_24px"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Riwayat Transaksi"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

        <!-- Subjudul -->
        <TextView
            android:id="@+id/tvSubjudul"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Semua transaksi yang Anda proses akan tampil di sini"
            android:textSize="12sp"
            android:textColor="#CCFFFFFF"/>

    </LinearLayout>

    <!-- Search & filter tanggal -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Cari kode transaksi..."
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/edittext_rounded"
                android:textSize="13sp"
                android:textColor="#1A1A2E"
                android:textColorHint="#B0BEC5"
                android:layout_marginEnd="8dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"/>

            <EditText
                android:id="@+id/etTanggal"
                android:layout_width="150dp"
                android:layout_height="48dp"
                android:focusable="false"
                android:clickable="true"
                android:paddingStart="14dp"
                android:paddingEnd="10dp"
                android:background="@drawable/edittext_rounded"
                android:textSize="13sp"
                android:textColor="#1A1A2E"
                android:textColorHint="#B0BEC5"
                android:layout_marginEnd="8dp"
                android:gravity="center_vertical"
                android:drawableEnd="@drawable/ic_calendar"
                android:drawablePadding="6dp"/>

            <Button
                android:id="@+id/btnReset"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Reset"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- List riwayat -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRiwayat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- Tampil kalau data kosong -->
        <LinearLayout
            android:id="@+id/llKosong"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧾"
                android:textSize="40sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum ada riwayat transaksi"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transaksi yang kamu lakukan akan muncul di sini"
                android:textSize="12sp"
                android:textColor="#78909C"/>
        </LinearLayout>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- ==================== PAGINATION ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- Info Halaman sekarang dipindah ke sebelah kiri -->
        <TextView
            android:id="@+id/tvInfoHalaman"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start|center_vertical"
            android:text="Halaman 1 dari 1"
            android:textSize="12sp"
            android:textColor="#78909C"/>

        <!-- Container untuk < prev 1 2 3 next > sekarang bergeser ke sebelah kanan -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnPrevHalaman"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="‹"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null"/>

            <!-- Container dinamis untuk menampung nomor halaman (1 2 3 dst) -->
            <LinearLayout
                android:id="@+id/llNomorHalamanContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnNextHalaman"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="›"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>