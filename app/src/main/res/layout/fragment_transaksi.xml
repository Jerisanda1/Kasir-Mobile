<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Judul menu, tanpa icon -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Transaksi"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#5149E5" />

            <!-- Tanggal, di kanan atas -->
            <TextView
                android:id="@+id/tvTanggal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#78909C"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Deskripsi di bawah judul -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Cari produk atau scan barcode untuk mulai transaksi"
            android:textSize="12sp"
            android:textColor="#78909C" />

    </LinearLayout>



    <!-- Konten 2 kolom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- ==================== KOLOM KIRI: Pencarian, Kategori & Produk ==================== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.3"
            android:orientation="vertical"
            android:layout_marginEnd="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daftar Produk"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"
                            android:layout_marginBottom="8dp"/>

                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginBottom="10dp"
                            android:hint="Cari produk atau scan barcode..."
                            android:paddingStart="16dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/edittext_rounded"
                            android:textSize="14sp"
                            android:textColor="#1A1A2E"
                            android:textColorHint="#B0BEC5"
                            android:inputType="text"
                            android:imeOptions="actionDone"
                            android:singleLine="true"
                            android:drawableEnd="@drawable/ic_barcode"
                            android:drawablePadding="8dp"/>

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none">

                            <LinearLayout
                                android:id="@+id/llKategori"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"/>

                        </HorizontalScrollView>

                    </LinearLayout>

                    <!-- Garis pemisah -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#ECEFF1"/>

                    <!-- Daftar Produk -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvProduk"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:clipToPadding="false"
                        android:padding="10dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ==================== KOLOM KANAN: Keranjang & Pembayaran (TANPA SCROLL) ==================== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Keranjang Belanja"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>

                        <Button
                            android:id="@+id/btnReset"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_gravity="center_vertical"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:paddingHorizontal="16dp"
                            android:text="Reset"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#5149E5"
                            android:background="@drawable/bg_button_rounded"
                            android:backgroundTint="#EEF0FB"
                            android:stateListAnimator="@null"/>
                    </LinearLayout>

                    <!-- Garis pemisah -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#ECEFF1"/>

                    <!-- Isi Keranjang -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvKeranjang"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="14dp"
                            android:clipToPadding="false"/>

                        <LinearLayout
                            android:id="@+id/llKeranjangKosong"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="20dp">

                            <ImageView
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:src="@drawable/no_data"
                                android:alpha="0.4"
                                android:layout_marginBottom="10dp"
                                android:contentDescription="Keranjang kosong"/>

                            <TextView
                                android:id="@+id/tvKeranjangKosong"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Keranjang masih kosong"
                                android:textSize="12sp"
                                android:textColor="#78909C"
                                android:gravity="center"/>
                        </LinearLayout>

                    </FrameLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Diskon: ringkas, 1 baris -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Diskon (%)"
                        android:textSize="12sp"
                        android:textColor="#78909C"
                        android:layout_marginEnd="10dp"/>

                    <EditText
                        android:id="@+id/etDiskon"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:hint="0"
                        android:inputType="number"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/edittext_rounded"
                        android:textSize="13sp"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#B0BEC5"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pembayaran: selalu terlihat penuh, wrap_content -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:id="@+id/llKontenPembayaran"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Subtotal"
                            android:textSize="12sp"
                            android:textColor="#78909C"/>
                        <TextView
                            android:id="@+id/tvSubtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Diskon"
                            android:textSize="12sp"
                            android:textColor="#78909C"/>
                        <TextView
                            android:id="@+id/tvDiskon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="- Rp 0"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#C62828"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TOTAL"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#5149E5"/>
                        <TextView
                            android:id="@+id/tvTotalBayar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#5149E5"/>
                    </LinearLayout>

                    <!-- Pilihan Metode Pembayaran: toggle dengan indikator geser + outline,
                         niru pola sliding indicator di sidebar (lihat MainActivity.geserIndikatorKe) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Metode Pembayaran"
                        android:textSize="12sp"
                        android:textColor="#78909C"
                        android:layout_marginBottom="6dp"/>

                    <FrameLayout
                        android:id="@+id/flMetodeToggle"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_toggle_container"
                        android:padding="3dp"
                        android:layout_marginBottom="12dp">

                        <!-- Indikator: digeser (translationX) ke tombol yang dipilih, lihat pilihMetodePembayaran() -->
                        <View
                            android:id="@+id/vIndikatorMetode"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_toggle_indikator"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnMetodeTunai"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="Tunai"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:minWidth="0dp"
                                android:padding="0dp"
                                android:background="@android:color/transparent"
                                android:stateListAnimator="@null"/>

                            <Button
                                android:id="@+id/btnMetodeQris"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="QRIS"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:minWidth="0dp"
                                android:padding="0dp"
                                android:background="@android:color/transparent"
                                android:stateListAnimator="@null"/>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- Input Jumlah Bayar: hanya relevan untuk Tunai, disembunyikan saat QRIS -->
                    <EditText
                        android:id="@+id/etJumlahBayar"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Jumlah bayar"
                        android:inputType="numberDecimal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/edittext_rounded"
                        android:textSize="13sp"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#B0BEC5"
                        android:layout_marginBottom="8dp"/>

                    <!-- Kembalian: SELALU tampil baik Tunai maupun QRIS (QRIS = tetap Rp 0, pas),
                         supaya tinggi layout tidak berubah drastis saat ganti metode -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Kembalian"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>
                        <TextView
                            android:id="@+id/tvKembalian"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#C62828"/>
                    </LinearLayout>

                    <!-- Catatan QRIS: simpel, tanpa icon, tampil cuma saat QRIS dipilih -->
                    <TextView
                        android:id="@+id/tvCatatanQris"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dibayar pas via QRIS, tanpa kembalian"
                        android:textSize="11sp"
                        android:textColor="#78909C"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone"/>

                    <Button
                        android:id="@+id/btnBayar"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="PROSES PEMBAYARAN"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_button_rounded"
                        android:backgroundTint="#048967"
                        android:stateListAnimator="@null"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>