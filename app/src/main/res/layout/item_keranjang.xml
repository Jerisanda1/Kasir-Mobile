<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Nama dan harga satuan -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNamaItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Barang"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"/>

        <TextView
            android:id="@+id/tvHargaSatuanItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 0 / pcs"
            android:textSize="11sp"
            android:textColor="#78909C"/>
    </LinearLayout>

    <!-- Tombol kurang -->
    <TextView
        android:id="@+id/btnKurang"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:text="-"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#5149E5"
        android:gravity="center"
        android:background="@drawable/bg_circle_outline"/>

    <!-- Jumlah -->
    <TextView
        android:id="@+id/tvJumlahItem"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"/>

    <!-- Tombol tambah -->
    <TextView
        android:id="@+id/btnTambah"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:text="+"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#5149E5"
        android:gravity="center"
        android:background="@drawable/bg_circle_outline"
        android:layout_marginEnd="10dp"/>

    <!-- Subtotal item -->
    <TextView
        android:id="@+id/tvSubtotalItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rp 0"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:minWidth="70dp"
        android:gravity="end"/>

    <!-- Tombol hapus item dari keranjang -->
    <TextView
        android:id="@+id/btnHapusItem"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="6dp"
        android:text="🗑"
        android:textSize="16sp"
        android:background="@drawable/bg_circle_outline"
        android:gravity="center"/>

</LinearLayout>