<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp"
    android:background="@drawable/bg_item_keranjang"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:padding="8dp">

    <!-- Informasi Produk -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNamaItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Sprite"
            android:textColor="#202124"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvHargaSatuanItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp7.000"
                android:textColor="#7A7A7A"
                android:textSize="10sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="•"
                android:textColor="#BDBDBD"
                android:textSize="10sp"/>

            <TextView
                android:id="@+id/tvSubtotalItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Rp21.000"
                android:textColor="#5149E5"
                android:textSize="11sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Qty -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/bg_qty"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnKurang"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="5dp"
            android:src="@drawable/remove_24px"
            app:tint="#5149E5"/>

        <TextView
            android:id="@+id/tvJumlahItem"
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="3"
            android:textColor="#202124"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <ImageButton
            android:id="@+id/btnTambah"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="5dp"
            android:src="@drawable/add_24px"
            app:tint="#5149E5"/>

    </LinearLayout>

    <!-- Hapus -->
    <ImageButton
        android:id="@+id/btnHapusItem"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="5dp"
        android:src="@drawable/delete_24px"
        app:tint="#E53935"/>

</LinearLayout>