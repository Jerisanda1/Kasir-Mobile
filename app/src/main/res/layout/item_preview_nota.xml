<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="2dp"
    android:paddingBottom="4dp">

    <!-- Nama produk (kiri) + subtotal (kanan) satu baris, niru web -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvPreviewNamaProduk"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nama Produk"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#1A1A2E"/>

        <TextView
            android:id="@+id/tvPreviewSubtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 0"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textColor="#1A1A2E"/>
    </LinearLayout>

    <!-- Qty x harga satuan, baris terpisah, rata kiri saja -->
    <TextView
        android:id="@+id/tvPreviewQtyHarga"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1 x Rp 0"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:textColor="#78909C"/>

    <!-- Garis tipis pemisah antar item (niru border-bottom dashed #eee di web) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="................................"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:textColor="#E0E0E0"
        android:gravity="center"
        android:maxLines="1"
        android:layout_marginTop="2dp"/>
</LinearLayout>
